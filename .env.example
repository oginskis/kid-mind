# Anthropic API key — required when not logged into Claude Code CLI.
# Get yours at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ChromaDB connection (defaults shown)
CHROMADB_HOST=localhost
CHROMADB_PORT=8000

# Embedding configuration
# Leave OPENAI_API_KEY blank to use local sentence-transformers (all-MiniLM-L6-v2).
# When OPENAI_API_KEY is set, defaults to text-embedding-3-small.
# Override the model name with EMBEDDING_MODEL if needed.
OPENAI_API_BASE=
OPENAI_API_KEY=
EMBEDDING_MODEL=

# Example: OpenAI-compatible endpoint
# OPENAI_API_BASE=https://your-endpoint.com/v1
# OPENAI_API_KEY=sk-...
# EMBEDDING_MODEL=text-embedding-3-small
