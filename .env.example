# ── Inference (LLM) ──────────────────────────────────────────────────────────
#
# MODEL is the model name, same var for all providers.
#
# If GEMINI_API_KEY is set → native Gemini provider.
# Otherwise → OpenAI-compatible (OPENAI_API_BASE / OPENAI_API_KEY).
#
# Gemini:  GEMINI_API_KEY=AIza...  MODEL=gemini-2.5-flash
# Ollama:  OPENAI_API_BASE=http://localhost:11434/v1  OPENAI_API_KEY=ollama  MODEL=qwen3:30b
# OpenAI:  OPENAI_API_BASE=https://api.openai.com/v1  OPENAI_API_KEY=sk-...  MODEL=gpt-4.1
#          (Requires Tier 2+, $50 paid. Tier 1 = 30k TPM limit.)

# GEMINI_API_KEY=
OPENAI_API_BASE=http://localhost:11434/v1
OPENAI_API_KEY=ollama
MODEL=qwen3:30b

# ── Embeddings ───────────────────────────────────────────────────────────────
#
# Can use a different provider than inference.
# Falls back to OPENAI_API_BASE/KEY if not set. No API key → local sentence-transformers.
# IMPORTANT: query-time model must match the one used for indexing.

# EMBEDDING_API_BASE=
# EMBEDDING_API_KEY=
EMBEDDING_MODEL=nomic-embed-text

# ── ChromaDB ─────────────────────────────────────────────────────────────────

CHROMADB_HOST=localhost
CHROMADB_PORT=8000

# ── Reranker ─────────────────────────────────────────────────────────────────

RERANKER_ENABLED=true
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ── Observability (optional) ─────────────────────────────────────────────────

# PHOENIX_COLLECTOR_ENDPOINT=
# PHOENIX_API_KEY=
# PHOENIX_PROJECT=kid-mind

# ── Agent backend ────────────────────────────────────────────────────────────
# "pydantic" (default) or "claude" (requires ANTHROPIC_API_KEY)

# ANTHROPIC_API_KEY=
AGENT_BACKEND=pydantic
